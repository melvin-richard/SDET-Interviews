    <div class="problem-card-header"><span class="problem-number">#238</span><h3 class="problem-heading" style="margin:0">Product of Array Except Self</h3><span class="tag tag-orange">Medium</span></div>
    <div class="problem-card-body">
      <div class="technique-row"><span class="technique-label">🎯 Technique</span><span class="tag tag-blue">Prefix &amp; Suffix Products</span><span class="tag tag-purple">In-Place Output Array</span></div>
      <div class="panel info"><span class="panel-icon">💡</span><div class="panel-content"><strong>Approach — Prefix × Suffix (No Division)</strong>First pass fills result with left prefix products. Second pass (right to left) multiplies by a running suffix product. Eliminates the need for division and uses no extra array beyond the output.</div></div>
      <table class="complexity-table"><thead><tr><th>Metric</th><th>Complexity</th><th>Notes</th></tr></thead><tbody><tr><td>Time</td><td class="complexity-time">O(n)</td><td>Two passes</td></tr><tr><td>Space</td><td class="complexity-space">O(1)</td><td>Output array not counted</td></tr></tbody></table>
      <div class="code-block"><div class="code-header"><span class="code-lang">Java</span><span class="code-title">Product of Array Except Self</span></div><pre><span class="kw">class</span> <span class="tp">Solution</span> {
    <span class="kw">public int</span>[] <span class="fn">productExceptSelf</span>(<span class="kw">int</span>[] nums) {
        <span class="kw">int</span> n = nums.length;
        <span class="kw">int</span>[] result = <span class="kw">new int</span>[n];
        result[<span class="nm">0</span>] = <span class="nm">1</span>;
        <span class="kw">for</span> (<span class="kw">int</span> i = <span class="nm">1</span>; i &lt; n; i++) result[i] = result[i-<span class="nm">1</span>] * nums[i-<span class="nm">1</span>];
        <span class="kw">int</span> suffix = <span class="nm">1</span>;
        <span class="kw">for</span> (<span class="kw">int</span> i = n-<span class="nm">1</span>; i &gt;= <span class="nm">0</span>; i--) { result[i] *= suffix; suffix *= nums[i]; }
        <span class="kw">return</span> result;
    }
}</pre></div>
    </div>
  </div>

