      <div class="code-block"><div class="code-header"><span class="code-lang">Java</span><span class="code-title">Merge Intervals</span></div><pre><span class="kw">import</span> java.util.*;
<span class="kw">class</span> <span class="tp">Solution</span> {
    <span class="kw">public int</span>[][] <span class="fn">merge</span>(<span class="kw">int</span>[][] intervals) {
        <span class="tp">Arrays</span>.sort(intervals, (a,b) -&gt; a[<span class="nm">0</span>]-b[<span class="nm">0</span>]);
        <span class="tp">List</span>&lt;<span class="kw">int</span>[]&gt; merged = <span class="kw">new</span> <span class="tp">ArrayList</span>&lt;&gt;();
        <span class="kw">int</span>[] current = intervals[<span class="nm">0</span>];
        <span class="kw">for</span> (<span class="kw">int</span>[] iv : intervals) {
            <span class="kw">if</span> (iv[<span class="nm">0</span>] &lt;= current[<span class="nm">1</span>]) {
                current[<span class="nm">1</span>] = <span class="tp">Math</span>.max(current[<span class="nm">1</span>], iv[<span class="nm">1</span>]);
            }
            <span class="kw">else</span> {
                 { merged.add(current);
            } current = iv; }
        }
        merged.add(current);
        <span class="kw">return</span> merged.toArray(<span class="kw">new int</span>[<span class="nm">0</span>][]);
    }
}</pre></div>
