    <div class="problem-card-header"><span class="problem-number">#15</span><h3 class="problem-heading" style="margin:0">3Sum</h3><span class="tag tag-orange">Medium</span></div>
    <div class="problem-card-body">
      <div class="technique-row"><span class="technique-label">🎯 Technique</span><span class="tag tag-blue">Two Pointers</span><span class="tag tag-purple">Sort + Dedup</span></div>
      <div class="panel info"><span class="panel-icon">💡</span><div class="panel-content"><strong>Approach — Sort + Two Pointers</strong>Sort the array. Fix one element with an outer loop. Use two pointers (left, right) to find pairs summing to its negation. Skip duplicate values at every pointer position to avoid duplicate triplets in the result.</div></div>
      <table class="complexity-table"><thead><tr><th>Metric</th><th>Complexity</th><th>Notes</th></tr></thead><tbody><tr><td>Time</td><td class="complexity-time">O(n²)</td><td>Outer loop × inner two-pointer scan</td></tr><tr><td>Space</td><td class="complexity-space">O(log n)</td><td>Sorting stack space</td></tr></tbody></table>
      <div class="code-block"><div class="code-header"><span class="code-lang">Java</span><span class="code-title">3Sum — Sort + Two Pointers</span></div><pre><span class="kw">import</span> java.util.*;
<span class="kw">class</span> <span class="tp">Solution</span> {
    <span class="kw">public</span> <span class="tp">List</span>&lt;<span class="tp">List</span>&lt;<span class="tp">Integer</span>&gt;&gt; <span class="fn">threeSum</span>(<span class="kw">int</span>[] nums) {
        <span class="tp">Arrays</span>.sort(nums);
        <span class="tp">List</span>&lt;<span class="tp">List</span>&lt;<span class="tp">Integer</span>&gt;&gt; result = <span class="kw">new</span> <span class="tp">ArrayList</span>&lt;&gt;();
        <span class="kw">for</span> (<span class="kw">int</span> i = <span class="nm">0</span>; i &lt; nums.length - <span class="nm">2</span>; i++) {
            <span class="kw">if</span> (i &gt; <span class="nm">0</span> &amp;&amp; nums[i] == nums[i-<span class="nm">1</span>]) {
                 <span class="kw">continue</span>;
            }
            <span class="kw">int</span> left = i+<span class="nm">1</span>, right = nums.length-<span class="nm">1</span>;
            <span class="kw">while</span> (left &lt; right) {
                <span class="kw">int</span> sum = nums[i] + nums[left] + nums[right];
                <span class="kw">if</span> (sum == <span class="nm">0</span>) {
                    result.add(<span class="tp">Arrays</span>.asList(nums[i], nums[left], nums[right]));
                    <span class="kw">while</span> (left &lt; right &amp;&amp; nums[left]==nums[left+<span class="nm">1</span>]) left++;
                    <span class="kw">while</span> (left &lt; right &amp;&amp; nums[right]==nums[right-<span class="nm">1</span>]) right--;
                    left++; right--;
                } <span class="kw">else if</span> (sum &lt; <span class="nm">0</span>) {
                left++;
            }
                <span class="kw">else</span> {
                right--;
            }
            }
        }
        <span class="kw">return</span> result;
    }
}</pre></div>
