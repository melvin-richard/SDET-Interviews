  <div class="problem-card">
    <div class="problem-card-header"><span class="problem-number">#28</span><h3 class="problem-heading" style="margin:0">Find First Occurrence in a String</h3><span class="tag tag-green">Easy</span></div>
    <div class="problem-card-body">
      <div class="technique-row"><span class="technique-label">🎯 Technique</span><span class="tag tag-blue">KMP Algorithm</span><span class="tag tag-purple">Failure Function / LPS Array</span></div>
      <div class="panel info"><span class="panel-icon">💡</span><div class="panel-content"><strong>Approach — KMP (Knuth-Morris-Pratt)</strong>Build an LPS (Longest Proper Prefix which is also Suffix) array for the pattern. During matching, when a mismatch occurs, use the LPS array to skip back intelligently instead of restarting — achieving O(n+m) time.</div></div>
      <table class="complexity-table"><thead><tr><th>Metric</th><th>Complexity</th><th>Notes</th></tr></thead><tbody><tr><td>Time</td><td class="complexity-time">O(n+m)</td><td>n=haystack, m=needle</td></tr><tr><td>Space</td><td class="complexity-space">O(m)</td><td>LPS array for pattern</td></tr></tbody></table>
      <div class="code-block"><div class="code-header"><span class="code-lang">Java</span><span class="code-title">KMP String Search</span></div><pre><span class="kw">class</span> <span class="tp">Solution</span> {
    <span class="kw">public int</span> <span class="fn">strStr</span>(<span class="tp">String</span> haystack, <span class="tp">String</span> needle) {
        <span class="kw">int</span> n=haystack.length(), m=needle.length();
        <span class="kw">if</span>(m==<span class="nm">0</span>) {
                 <span class="kw">return</span> <span class="nm">0</span>;
            }
        <span class="kw">int</span>[] lps = <span class="fn">buildLPS</span>(needle);
        <span class="kw">int</span> i=<span class="nm">0</span>, j=<span class="nm">0</span>;
        <span class="kw">while</span>(i &lt; n) {
            <span class="kw">if</span>(haystack.charAt(i) {
                ==needle.charAt(j)) { i++;
            } j++; }
            <span class="kw">if</span>(j==m) {
                 <span class="kw">return</span> i-j;
            }
            <span class="kw">else if</span>(i &lt; n &amp;&amp; haystack.charAt(i)!=needle.charAt(j))
                j = (j!=<span class="nm">0</span>) ? lps[j-<span class="nm">1</span>] : (++i &amp; <span class="nm">0</span>);
        }
        <span class="kw">return</span> -<span class="nm">1</span>;
    }
    <span class="kw">private int</span>[] <span class="fn">buildLPS</span>(<span class="tp">String</span> p) {
        <span class="kw">int</span>[] lps = <span class="kw">new int</span>[p.length()]; <span class="kw">int</span> len=<span class="nm">0</span>, i=<span class="nm">1</span>;
        <span class="kw">while</span>(i &lt; p.length()) {
            <span class="kw">if</span>(p.charAt(i) {
                ==p.charAt(len)) lps[i++]=++len;
            }
            <span class="kw">else if</span>(len!=<span class="nm">0</span>) {
                len=lps[len-<span class="nm">1</span>];
            }
            <span class="kw">else</span> {
                lps[i++]=<span class="nm">0</span>;
            }
        }
        <span class="kw">return</span> lps;
    }
}</pre></div>
