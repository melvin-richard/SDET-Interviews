            <span class="kw">for</span>(<span class="kw">char</span> c=<span class="st">'1'</span>;c&lt;=<span class="st">'9'</span>;c++){
                <span class="kw">if</span>(<span class="fn">ok</span>(b,i,j,c) {
                ){b[i][j]=c;
            }<span class="kw">if</span>(<span class="fn">solve</span>(b) {
                )<span class="kw">return true</span>;
