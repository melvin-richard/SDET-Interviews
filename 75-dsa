    --panel-warn:    #FFFAE6;
    --panel-warn-border: #FF991F;
    --code-bg:       #F4F5F7;
    --code-border:   #DFE1E6;
    --tag-blue:      #DEEBFF;
    --tag-blue-text: #0747A6;
    --tag-green:     #E3FCEF;
    --tag-green-text:#006644;
    --tag-purple:    #EAE6FF;
    --tag-purple-text:#403294;
    --tag-teal:      #E6FCFF;
    --tag-teal-text: #006694;
    --tag-orange:    #FFFAE6;
    --tag-orange-text:#974F0C;
    --tag-red:       #FFEBE6;
    --tag-red-text:  #BF2600;
    --heading1:      #172B4D;
    --heading2:      #0052CC;
    --divider:       #DFE1E6;
