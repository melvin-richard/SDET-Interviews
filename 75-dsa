            <span class="kw">if</span>(i&gt;start&amp;&amp;nums[i]==nums[i-<span class="nm">1</span>])<span class="kw">continue</span>;
            cur.add(nums[i]);<span class="fn">bt</span>(nums,i+<span class="nm">1</span>,cur,res);cur.remove(cur.size()-<span class="nm">1</span>);
        }
